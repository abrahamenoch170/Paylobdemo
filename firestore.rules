rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, displayName, role, payoutInfo, createdAt
    //
    // Collection: projects
    // Fields: title, description, clientId, freelancerId, status, totalValue, createdAt
    //
    // Collection: milestones
    // Fields: projectId, title, amount, state, deliveryType, paymentRef, updatedAt
    //
    // Collection: disputes
    // Fields: milestoneId, projectId, category, description, status, filedBy, auditLog
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isProjectParticipant(projectId) {
      let project = get(/databases/$(database)/documents/projects/$(projectId)).data;
      return isAuthenticated() && (request.auth.uid == project.clientId || request.auth.uid == project.freelancerId);
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "abrahamenoch170@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.uid is string && 
             data.email is string &&
             data.displayName is string &&
             data.displayName.size() < 100 &&
             (!('role' in data) || data.role in ['client', 'freelancer', 'admin']);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Rules
    
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) || isAdmin()) && 
                      isValidUser(request.resource.data) && 
                      (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.clientId || request.auth.uid == resource.data.freelancerId || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.clientId || request.auth.uid == resource.data.freelancerId || isAdmin());

      match /messages/{messageId} {
        allow read, write: if isProjectParticipant(projectId);
      }
    }

    match /milestones/{milestoneId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (isProjectParticipant(resource.data.projectId) || isAdmin());
    }

    match /disputes/{disputeId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.filedBy || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow write: if false; // System generated via Admin SDK
      allow update: if isAuthenticated() && 
                      request.auth.uid == resource.data.userId && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
    }

    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.customerUid || isAdmin());
      allow write: if false; // Server-side only
    }
  }
}
