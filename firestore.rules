rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function projectDoc(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId));
    }

    function isProjectParticipantById(projectId) {
      return isSignedIn() && (
        isAdmin() ||
        (projectDoc(projectId).data.clientId == request.auth.uid) ||
        (projectDoc(projectId).data.freelancerId == request.auth.uid)
      );
    }

    match /users/{userId} {
      allow read, create, update: if isSelf(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow create: if isSignedIn() && request.resource.data.clientId == request.auth.uid;
      allow read, update: if isProjectParticipantById(projectId);
      allow delete: if isAdmin();
    }

    match /milestones/{milestoneId} {
      allow create: if isSignedIn() && isProjectParticipantById(request.resource.data.projectId);
      allow read, update: if isProjectParticipantById(resource.data.projectId);
      allow delete: if isAdmin();
    }

    match /files/{fileId} {
      allow create: if isSignedIn() && (
        request.resource.data.ownerId == request.auth.uid || isAdmin()
      ) && isProjectParticipantById(request.resource.data.projectId);
      allow read, update: if isProjectParticipantById(resource.data.projectId);
      allow delete: if isAdmin();
    }

    match /contracts/{contractId} {
      allow create: if isSignedIn() && isProjectParticipantById(request.resource.data.projectId);
      allow read, update: if isSignedIn() && (
        isAdmin() ||
        resource.data.clientId == request.auth.uid ||
        resource.data.freelancerId == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    match /signature_audit/{auditId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (
        isAdmin() ||
        exists(/databases/$(database)/documents/contracts/$(resource.data.contractId)) &&
        (
          get(/databases/$(database)/documents/contracts/$(resource.data.contractId)).data.clientId == request.auth.uid ||
          get(/databases/$(database)/documents/contracts/$(resource.data.contractId)).data.freelancerId == request.auth.uid
        )
      );
      allow update, delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow create, read: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /disputes/{disputeId} {
      allow create: if isSignedIn() && isProjectParticipantById(request.resource.data.projectId);
      allow read, update: if isProjectParticipantById(resource.data.projectId);
      allow delete: if isAdmin();
    }

    match /changeOrders/{changeOrderId} {
      allow create: if isSignedIn() && isProjectParticipantById(request.resource.data.projectId);
      allow read, update: if isProjectParticipantById(resource.data.projectId);
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow create: if isSignedIn() && isProjectParticipantById(request.resource.data.projectId);
      allow read: if isSignedIn() && isProjectParticipantById(resource.data.projectId);
      allow update, delete: if isAdmin();
    }
  }
}
