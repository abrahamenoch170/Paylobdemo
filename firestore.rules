rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isParticipant(data) {
      return isAuthenticated() && (
        data.clientId == request.auth.uid ||
        data.freelancerId == request.auth.uid ||
        (data.participantIds is list && request.auth.uid in data.participantIds)
      );
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /projects/{projectId} {
      allow create: if isAuthenticated() && request.resource.data.clientId == request.auth.uid;
      allow read, update, delete: if isParticipant(resource.data);
    }

    match /milestones/{milestoneId} {
      allow create: if isAuthenticated() && request.resource.data.clientId == request.auth.uid;
      allow read, update, delete: if isParticipant(resource.data);
    }

    match /contracts/{contractId} {
      allow create: if isAuthenticated() && request.resource.data.clientId == request.auth.uid;
      allow read, update, delete: if isParticipant(resource.data);
    }

    match /files/{fileId} {
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && (
        resource.data.ownerId == request.auth.uid ||
        isParticipant(resource.data)
      );
    }

    match /payments/{paymentId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isParticipant(resource.data)
      );
      allow update, delete: if false;
    }

    match /disputes/{disputeId} {
      allow create: if isAuthenticated() && request.resource.data.createdBy == request.auth.uid;
      allow read, update: if isParticipant(resource.data) || resource.data.createdBy == request.auth.uid;
      allow delete: if false;
    }

    match /changeOrders/{changeOrderId} {
      allow create: if isAuthenticated() && request.resource.data.createdBy == request.auth.uid;
      allow read, update: if isParticipant(resource.data);
      allow delete: if false;
    }

    match /notifications/{notificationId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /messages/{messageId} {
      allow create: if isParticipant(request.resource.data);
      allow read, update, delete: if isParticipant(resource.data);
    }

    match /signature_audit/{auditId} {
      allow create: if isAuthenticated();
      allow read: if isParticipant(resource.data);
      allow update, delete: if false;
    }
  }
}
